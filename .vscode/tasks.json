{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-debug",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "-c",
                "Debug",
                "${workspaceRoot}/Src/AngryWasp.BasicScript.Interpreter.slnx"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Publish to Nuget",
            "type": "shell",
            "command": "bsi",
            "args": [
                "${workspaceFolder}/External/AngryWasp.Build/publish.bs",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}