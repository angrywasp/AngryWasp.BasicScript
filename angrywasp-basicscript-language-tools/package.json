{
    "name": "angrywasp-basicscript-language-tools",
    "displayName": "Basic Script Language Tools",
    "description": "Language tools for BasicScript",
    "publisher": "Angry Wasp",
    "version": "0.0.2",
    "engines": {
        "vscode": "^1.78.0"
    },
    "categories": [
        "Programming Languages",
        "Themes"
    ],
    "contributes": {
        "languages": [
            {
                "id": "bs",
                "aliases": [
                    "BasicScript",
                    "bs"
                ],
                "extensions": [
                    ".bs"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "bs",
                "scopeName": "source.bs",
                "path": "./syntaxes/bs.json"
            }
        ],
        "themes": [
            {
                "label": "Wasp",
                "uiTheme": "vs-dark",
                "path": "./themes/wasp-theme.json"
            }
        ]
    }
}